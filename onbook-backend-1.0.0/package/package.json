{
  "name": "@onbook/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docker:up": "docker compose -f ./docker-compose.yml -p onbook up -d",
    "migration:generate": "bun run drizzle-kit generate --config=./drizzle/config.ts",
    "migration:up": "bun run drizzle/migration-up",
    "build": "bun tsc --project tsconfig.build.json",
    "start": "bun ./dist/main.js",
    "test": "jest --config jest.config.js --runInBand"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.28.16",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "^1.3.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.5",
    "cpy": "^12.1.0",
    "cpy-cli": "^6.0.0",
    "drizzle-kit": "^0.31.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-neverthrow": "^1.1.4",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
